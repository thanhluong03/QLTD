@model List<UserModel>

@{
    ViewData["Title"] = "Danh Sách User";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="content-header">
    <h1><i class="fas fa-users"></i> Danh Sách Người Dùng HR</h1>
</div>

<div class="content-body">
    <div class="card">
        <div class="card-header">
            <i class="fas fa-list"></i> Danh Sách User (Chỉ HR)
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tên Người Dùng</th>
                        <th>Họ Tên</th>
                        <th>Email</th>
                        <th>Vị Trí</th>
                        <th>Trạng Thái</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.UserID</td>
                                <td>@user.UserName</td>
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td>@user.Position</td>
                                <td>
                                    @if (user.Status)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Không hoạt động</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("Delete", "User", new { id = user.UserID })" 
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Bạn chắc chắn muốn xóa user này?')">
                                        <i class="fas fa-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">Không có user HR nào</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
