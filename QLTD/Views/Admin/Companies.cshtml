@model List<CompanyModel>

@{
    ViewData["Title"] = "Danh Sách Công Ty";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="content-header">
    <h1><i class="fas fa-building"></i> Danh Sách Công Ty</h1>
</div>

<div class="content-body">
    <div class="card">
        <div class="card-header">
            <i class="fas fa-list"></i> Danh Sách Công Ty Hoạt Động
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tên Công Ty</th>
                        <th>Email</th>
                        <th>Quy Mô</th>
                        <th>Địa Chỉ</th>
                        <th>Trạng Thái</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var company in Model)
                        {
                            <tr>
                                <td>@company.CompanyID</td>
                                <td>@company.CompanyName</td>
                                <td>@company.Email</td>
                                <td>@company.Scalecompany</td>
                                <td>@company.Address</td>
                                <td>
                                    @if (company.Status)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Không hoạt động</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("Delete", "Company", new { id = company.CompanyID })" 
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Bạn chắc chắn muốn xóa công ty này?')">
                                        <i class="fas fa-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">Không có công ty nào</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
