@model QLTD.Models.CompanyModel
@{
    ViewData["Title"] = "Thông tin công ty";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="content-header">
    <h1>
        <i class="fas fa-building"></i> Thông tin công ty
    </h1>
</div>

<div class="content-body">
    @if (Model != null)
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <i class="fas fa-info-circle"></i> Chi tiết công ty
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6 class="text-muted">Tên công ty</h6>
                                <p class="fs-5 fw-bold">@Model.CompanyName</p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted">Email</h6>
                                <p class="fs-5">
                                    <a href="mailto:@Model.Email">@Model.Email</a>
                                </p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6 class="text-muted">Địa chỉ</h6>
                                <p class="fs-5">@Model.Address</p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted">Quy mô công ty</h6>
                                <p class="fs-5">@Model.Scalecompany</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6 class="text-muted">Trạng thái</h6>
                                <p>
                                    @if (Model.Status)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle"></i> Hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            <i class="fas fa-times-circle"></i> Ngừng hoạt động
                                        </span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning" role="alert">
            <i class="fas fa-exclamation-triangle"></i> Không tìm thấy thông tin công ty
        </div>
    }
</div>
