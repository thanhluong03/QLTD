@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="content-header">
    <h1><i class="fas fa-chart-line"></i> Bảng Điều Khiển</h1>
</div>

<div class="content-body">
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-building"></i> Quản Lý Công Ty
                </div>
                <div class="card-body p-4">
                    <p class="text-muted">Quản lý danh sách các công ty trong hệ thống</p>
                    <a href="@Url.Action("Companies", "Admin")" class="btn btn-primary">
                        <i class="fas fa-list"></i> Danh Sách Công Ty
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-users"></i> Quản Lý Người Dùng
                </div>
                <div class="card-body p-4">
                    <p class="text-muted">Quản lý danh sách các nhân viên HR trong hệ thống</p>
                    <a href="@Url.Action("Users", "Admin")" class="btn btn-primary">
                        <i class="fas fa-list"></i> Danh Sách User
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
