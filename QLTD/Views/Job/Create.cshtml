@model QLTD.Models.JobModel
@{
    ViewData["Title"] = "Thêm việc làm mới";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="content-header">
    <h1>
        <i class="fas fa-briefcase"></i> Thêm việc làm mới
    </h1>
</div>

<div class="content-body">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <form asp-action="Create" asp-controller="Job" method="post">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <h6>Vui lòng kiểm tra lại các trường dưới đây:</h6>
                                <div asp-validation-summary="All"></div>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                       
                            }
                        
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                            <div class="mb-3">
                                <label asp-for="Jobposition" class="form-label">Vị trí công việc *</label>
                                <input asp-for="Jobposition" class="form-control" placeholder="Ví dụ: Lập trình viên C#"
                                     required>
                                <span asp-validation-for="Jobposition" class="text-danger d-block"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Address" class="form-label">Địa chỉ công việc *</label>
                                <input asp-for="Address" class="form-control" placeholder="Ví dụ: Hà Nội, TP.HCM..."
                                     required>
                                <span asp-validation-for="Address" class="text-danger d-block"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Cash" class="form-label">Mức lương *</label>
                                <input asp-for="Cash" class="form-control" placeholder="Ví dụ: 10-15 triệu" required>
                                <span asp-validation-for="Cash" class="text-danger d-block"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Quantity" class="form-label">Số lượng cần tuyển *</label>
                                <input asp-for="Quantity" type="number" class="form-control" min="1" required>
                                <span asp-validation-for="Quantity" class="text-danger d-block"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Experien" class="form-label">Kinh nghiệm yêu cầu *</label>
                                <input asp-for="Experien" class="form-control" placeholder="Ví dụ: 3 năm" required>
                                <span asp-validation-for="Experien" class="text-danger d-block"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="WorkingStyle" class="form-label">Hình thức làm việc *</label>
                                <select asp-for="WorkingStyle" class="form-select" required>
                                    <option value="">-- Chọn hình thức --</option>
                                    <option value="Toàn thời gian">Toàn thời gian</option>
                                    <option value="Bán thời gian">Bán thời gian</option>
                                    <option value="Remote">Remote</option>
                                </select>
                                <span asp-validation-for="WorkingStyle" class="text-danger d-block"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="RequimentEducation" class="form-label">Yêu cầu bằng cấp *</label>
                                <select asp-for="RequimentEducation" class="form-select" required>
                                    <option value="">-- Chọn bằng cấp --</option>
                                    <option value="Cao đẳng">Cao đẳng</option>
                                    <option value="Đại học">Đại học</option>
                                    <option value="Thạc sĩ">Thạc sĩ</option>
                                    <option value="Tiến sĩ">Tiến sĩ</option>
                                    <option value="Không yêu cầu">Không yêu cầu</option>
                                </select>
                                <span asp-validation-for="RequimentEducation" class="text-danger d-block"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Description" class="form-label">Mô tả công việc *</label>
                                <textarea asp-for="Description" class="form-control" rows="5"
                                        placeholder="Nhập mô tả chi tiết về công việc..." required></textarea>
                                <span asp-validation-for="Description" class="text-danger d-block"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="StartTime" class="form-label">Ngày bắt đầu *</label>
                                        <input asp-for="StartTime" type="date" class="form-control" required>
                                        <span asp-validation-for="StartTime" class="text-danger d-block"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="EntimeTime" class="form-label">Ngày kết thúc *</label>
                                        <input asp-for="EntimeTime" type="date" class="form-control" required>
                                        <span asp-validation-for="EntimeTime" class="text-danger d-block"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-save"></i> Lưu
                                </button>
                                <a href="@Url.Action("Index", "Job")" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Hủy
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
