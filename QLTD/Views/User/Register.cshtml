@model UserRegistrationViewModel

@{
    ViewData["Title"] = "Đăng Ký Tài Khoản";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Đăng Ký Tài Khoản Người Dùng và Công Ty</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Register" asp-controller="User" method="post" id="registerForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <!-- Company Information Section -->
                        <div class="section-divider mb-4">
                            <h5 class="section-title">
                                <i class="fas fa-building"></i> Thông Tin Công Ty
                            </h5>
                            <hr />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Company.CompanyName" class="form-label">Tên Công Ty <span
                                    class="text-danger">*</span></label>
                                    <input asp-for="Company.CompanyName" class="form-control" placeholder="Nhập tên công ty"
                                           required />
                                    <span asp-validation-for="Company.CompanyName" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Company.Email" class="form-label">Email Công Ty <span
                                        class="text-danger">*</span></label>
                                        <input asp-for="Company.Email" type="email" class="form-control"
                                               placeholder="Nhập email công ty" required />
                                        <span asp-validation-for="Company.Email" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Company.Address" class="form-label">Địa Chỉ <span
                                            class="text-danger">*</span></label>
                                            <input asp-for="Company.Address" class="form-control" placeholder="Nhập địa chỉ công ty"
                                                   required />
                                            <span asp-validation-for="Company.Address" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label asp-for="Company.Scalecompany" class="form-label">Quy Mô Công Ty <span
                                                class="text-danger">*</span></label>
                                                <select asp-for="Company.Scalecompany" class="form-control" required>
                                                    <option value="">-- Chọn quy mô --</option>
                                                    <option value="Startup">Startup</option>
                                                    <option value="10-50 nhân viên">Nhỏ (10-50 nhân viên)</option>
                                                    <option value="50-200 nhân viên">Vừa (50-200 nhân viên)</option>
                                                    <option value="200-1000 nhân viên">Lớn (200-1000 nhân viên)</option>
                                                    <option value=">1000 nhân viên">Rất Lớn (>1000 nhân viên)</option>
                                                </select>
                                                <span asp-validation-for="Company.Scalecompany" class="text-danger"></span>
                                            </div>
                                        </div>

                                        <!-- User Information Section -->
                                        <div class="section-divider mb-4 mt-4">
                                            <h5 class="section-title">
                                                <i class="fas fa-user"></i> Thông Tin Người Dùng
                                            </h5>
                                            <hr />
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label asp-for="User.FullName" class="form-label">Họ và Tên <span
                                                    class="text-danger">*</span></label>
                                                    <input asp-for="User.FullName" class="form-control" placeholder="Nhập họ và tên"
                                                           required />
                                                    <span asp-validation-for="User.FullName" class="text-danger"></span>
                                                </div>
                                                <div class="col-md-6 mb-3">
                                                    <label asp-for="User.UserName" class="form-label">Tên Đăng Nhập <span
                                                        class="text-danger">*</span></label>
                                                        <input asp-for="User.UserName" class="form-control" placeholder="Nhập tên đăng nhập"
                                                               required />
                                                        <span asp-validation-for="User.UserName" class="text-danger"></span>
                                                    </div>
                                                </div>

                                                <div class="row">
                                                    <div class="col-md-6 mb-3">
                                                        <label asp-for="User.Email" class="form-label">Email <span
                                                            class="text-danger">*</span></label>
                                                            <input asp-for="User.Email" type="email" class="form-control" placeholder="Nhập email"
                                                                   required />
                                                            <span asp-validation-for="User.Email" class="text-danger"></span>
                                                        </div>
                                                        <div class="col-md-6 mb-3">
                                                            <label asp-for="User.Position" class="form-label">Chức Vị <span
                                                                class="text-danger">*</span></label>
                                                                <input asp-for="User.Position" class="form-control" placeholder="Nhập chức vị"
                                                                       required />
                                                                <span asp-validation-for="User.Position" class="text-danger"></span>
                                                            </div>
                                                        </div>

                                                        <div class="row">
                                                            <div class="col-md-6 mb-3">
                                                                <label asp-for="User.Password" class="form-label">Mật Khẩu <span
                                                                    class="text-danger">*</span></label>
                                                                    <input asp-for="User.Password" type="password" class="form-control"
                                                                           placeholder="Nhập mật khẩu" required />
                                                                    <span asp-validation-for="User.Password" class="text-danger"></span>
                                                                </div>
                                                                <div class="col-md-6 mb-3">
                                                                    <label class="form-label">Xác Nhận Mật Khẩu <span class="text-danger">*</span></label>
                                                                    <input type="password" id="confirmPassword" class="form-control"
                                                                           placeholder="Xác nhận mật khẩu" required />
                                                                </div>
                                                            </div>

                                                            <!-- Form Actions -->
                                                            <div class="mt-4 d-flex gap-2">
                                                                <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                                                                    <i class="fas fa-save"></i> Lưu & Đăng Ký
                                                                </button>
                                                                <a href="@Url.Action("Login", "Account")" class="btn btn-secondary btn-lg">
                                                                    <i class="fas fa-times"></i> Hủy
                                                                </a>
                                                            </div>

                                                            <div class="mt-3 text-center">
                                                                <p>Đã có tài khoản? <a href="@Url.Action("Login", "Account")" class="btn-link">Đăng nhập tại
                                                                    đây</a></p>
                                                                </div>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <style>
                                            .section-divider {
                                                display: flex;
                                                align-items: center;
                                                gap: 10px;
                                            }

                                            .section-title {
                                                margin: 0;
                                                color: #0d6efd;
                                                font-weight: 600;
                                            }

                                            .text-danger {
                                                color: #dc3545;
                                            }

                                            .form-control:focus {
                                                border-color: #0d6efd;
                                                box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
                                            }

                                            .btn-link {
                                                text-decoration: none;
                                                color: #0d6efd;
                                                cursor: pointer;
                                            }

                                            .btn-link:hover {
                                                text-decoration: underline;
                                            }
                                        </style>

                                        @section Scripts {
                                            <script>
                                                // Password validation
                                                document.getElementById('registerForm').addEventListener('submit', function (e) {
                                                    const password = document.querySelector('input[name="User.Password"]').value;
                                                    const confirmPassword = document.getElementById('confirmPassword').value;

                                                    if (password !== confirmPassword) {
                                                        e.preventDefault();
                                                        alert('Mật khẩu không khớp!');
                                                        return false;
                                                    }
                                                });
                                            </script>
                                        }
