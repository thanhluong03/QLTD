@model IEnumerable<QLTD.Models.UserModel>

@{
    ViewData["Title"] = "User List";
}


<a href="@Url.Action("Create", "User")" class="btn btn-primary mb-2">Add User</a>

<!-- Table as before -->
<table class="table table-bordered">
    <thead>
        <tr>
            <th>UserID</th>
            <th>FullName</th>
            <th>UserName</th>
            <th>Email</th>
            <th>Position</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var user in Model)
            {
                <tr>
                    <td>@user.UserID</td>
                    <td>@user.FullName</td>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td>@user.Position</td>
                    <td>@user.Status</td>
                    <td>
                        <a href="@Url.Action("Edit", "User", new { id = user.UserID })" class="btn btn-sm btn-warning">Edit</a>
                        <a href="@Url.Action("DeleteConfirm", "User", new { id = user.UserID })"
                           class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">No users found.</td>
            </tr>
        }
    </tbody>
</table>




