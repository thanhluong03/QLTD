@model QLTD.Models.UserModel
@{
    Layout = null;
}
<div class="mb-3">
    <label class="form-label">Full Name</label>
    <input type="text" class="form-control" name="FullName" value="@Model.FullName" required />
</div>
<div class="mb-3">
    <label class="form-label">User Name</label>
    <input type="text" class="form-control" name="UserName" value="@Model.UserName" required />
</div>
<div class="mb-3">
    <label class="form-label">Password</label>
    <input type="password" class="form-control" name="Password" value="@Model.Password" required />
</div>
<div class="mb-3">
    <label class="form-label">Email</label>
    <input type="email" class="form-control" name="Email" value="@Model.Email" required />
</div>
<div class="mb-3">
    <label class="form-label">Position</label>
    <input type="text" class="form-control" name="Position" value="@Model.Position" required />
</div>
<div class="mb-3">
    <label class="form-label">Status</label>
    <select class="form-control" name="Status" required>
        <option value="true" selected="@(Model.Status ? "selected" : null)">Active</option>
        <option value="false" selected="@(!Model.Status ? "selected" : null)">Inactive</option>
    </select>
</div>
<div class="mb-3">
    <label class="form-label">PermissionID</label>
    <input type="number" class="form-control" name="PermissionID" value="@Model.PermissionID" required />
</div>
<div class="mb-3">
    <label class="form-label">CompanyID</label>
    <input type="number" class="form-control" name="CompanyID" value="@Model.CompanyID" />
</div>
