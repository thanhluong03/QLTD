@model IEnumerable<QLTD.Models.ApplicationModel>
@{
    ViewData["Title"] = "Danh sách ứng tuyển";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="content-header">
    <h1>
        <i class="fas fa-file-alt"></i> Danh sách ứng tuyển
    </h1>
</div>

<div class="content-body">
    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th width="5%">#</th>
                        <th>Tên ứng viên</th>
                        <th>Vị trí ứng tuyển</th>
                        <th>Email</th>
                        <th>Điện thoại</th>
                        <th>Ngày ứng tuyển</th>
                        <th>Trạng thái</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int count = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@count</td>
                                <td>
                                    <strong>@item.UserName</strong>
                                    @if (item.Candidate != null)
                                    {
                                        <br>
                                        <small class="text-muted">@item.Candidate.FullName</small>
                                    }
                                </td>
                                <td>
                                    @if (item.Job != null)
                                    {
                                        <strong>@item.Job.Jobposition</strong>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td>
                                    <a href="mailto:@item.Email">@item.Email</a>
                                </td>
                                <td>@item.Phone</td>
                                <td>@item.ApplicationTime.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.view == "Pending")
                                    {
                                        <span class="badge bg-warning">Chờ xét duyệt</span>
                                    }
                                    else if (item.view == "Approved")
                                    {
                                        <span class="badge bg-success">Được chấp nhận</span>
                                    }
                                    else if (item.view == "Rejected")
                                    {
                                        <span class="badge bg-danger">Bị từ chối</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.view</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-info" title="Xem chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button class="btn btn-sm btn-success" title="Chấp nhận">
                                        <i class="fas fa-check"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" title="Từ chối">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </td>
                            </tr>
                            count++;
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="fas fa-info-circle"></i> Chưa có ứng tuyển nào
        </div>
    }
</div>
